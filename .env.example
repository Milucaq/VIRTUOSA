# Copia este archivo como ".env" y completa los valores reales.
# ".env" esta en .gitignore: nunca se sube al repositorio.

# --- Fase 1: configuracion base ---
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=tu-app.onrender.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com

# --- Fase 2: base de datos (Postgres en Railway) ---
# Copia el valor "DATABASE_URL" que te da Railway en la pestaña "Connect"
# de tu servicio Postgres. Si esta variable no existe, el proyecto usa
# SQLite local automaticamente (no rompe tu entorno de desarrollo).
DATABASE_URL=postgresql://usuario:password@host.railway.internal:5432/railway

# --- Fase 3: almacenamiento de media (Cloudinary) ---
# Crea una cuenta gratuita en https://cloudinary.com, y copia el valor
# "API Environment variable" de tu Dashboard (empieza con cloudinary://).
# Si esta variable no existe, las evidencias se guardan en disco local
# (no rompe tu entorno de desarrollo, pero no sobrevive a un redeploy).
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Fase 5: historial de cambios (MongoDB) ---
# Crea un cluster gratuito en https://www.mongodb.com/cloud/atlas y copia
# el connection string (boton "Connect" -> "Drivers"). Si esta variable
# no existe, el historial simplemente no se registra (no rompe la app).
MONGO_URI=mongodb+srv://usuario:password@cluster0.mongodb.net
MONGO_DB_NAME=virtuosa_historial

# --- Fase 7: notificaciones automaticas por email ---
# Si usas Gmail: activa verificacion en 2 pasos y genera una "contraseña
# de aplicacion" en https://myaccount.google.com/apppasswords (la
# contraseña normal de tu cuenta NO funciona con SMTP).
# Si EMAIL_BACKEND no se define, los correos solo se imprimen en consola
# (no se envian de verdad), util para desarrollo local.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=contraseña-de-aplicacion-de-16-caracteres
DEFAULT_FROM_EMAIL=tu-correo@gmail.com
# Correo fijo que recibe el aviso cuando un pedido pasa a "retrasado" o "finalizado"
NOTIFICATION_EMAIL=admin@virtuosa.pe
